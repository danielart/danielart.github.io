---
export interface Props {
  currentLang?: "en" | "es" | "ja" | "pt";
}

const { currentLang = "en" } = Astro.props;
---

<div class="language-switcher mb-6 flex gap-2">
  <a
    href="/posts/"
    class={`lang-btn rounded border border-border px-3 py-1 hover:border-accent ${
      currentLang === "en" ? "border-accent text-accent" : ""
    }`}
  >
    EN
  </a>
  <a
    href="/posts/es/"
    class={`lang-btn rounded border border-border px-3 py-1 hover:border-accent ${
      currentLang === "es" ? "border-accent text-accent" : ""
    }`}
  >
    ES
  </a>
  <a
    href="/posts/ja/"
    class={`lang-btn rounded border border-border px-3 py-1 hover:border-accent ${
      currentLang === "ja" ? "border-accent text-accent" : ""
    }`}
  >
    JA
  </a>
  <a
    href="/posts/pt/"
    class={`lang-btn rounded border border-border px-3 py-1 hover:border-accent ${
      currentLang === "pt" ? "border-accent text-accent" : ""
    }`}
  >
    PT
  </a>
</div>
