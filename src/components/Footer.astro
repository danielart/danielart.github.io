---
import type { HTMLAttributes } from "astro/types";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
  wide?: boolean;
} & HTMLAttributes<"footer">;

const {
  noMarginTop = false,
  wide = false,
  class: className,
  ...attrs
} = Astro.props;
---

<footer class:list={[{ "mt-auto": !noMarginTop }, className]} {...attrs}>
  <div
    class:list={[
      "flex flex-col items-center justify-between gap-4 border-t border-border/40 py-8 sm:flex-row sm:py-6",
      wide ? "wide-layout" : "app-layout",
    ]}
  >
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
      <a
        href="/posts"
        class="text-sm opacity-80 transition-all hover:text-accent hover:opacity-100"
        >Posts</a
      >
      <a
        href="/tags"
        class="text-sm opacity-80 transition-all hover:text-accent hover:opacity-100"
        >Tags</a
      >
      <a
        href="/about"
        class="text-sm opacity-80 transition-all hover:text-accent hover:opacity-100"
        >About</a
      >
      <a
        href="/#contact"
        class="text-sm opacity-80 transition-all hover:text-accent hover:opacity-100"
        >Contact</a
      >
    </div>
    <div
      class="flex flex-col items-center gap-4 font-mono text-xs tracking-wider opacity-60 sm:flex-row"
    >
      <span>© {currentYear} — Daniel Artola</span>
    </div>
  </div>
</footer>
