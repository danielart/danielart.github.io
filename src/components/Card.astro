---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;
const { title, description, lang, ...props } = data;
---

<li
  class="group relative block border-b border-border/30 py-6 transition-all duration-300 ease-out hover:pl-3"
  data-language={lang}
>
  <a href={getPath(id, filePath)} class="block outline-none">
    <div class="flex flex-col gap-1.5">
      <div class="font-mono text-xs tracking-wide text-foreground/60">
        <Datetime lang={lang} {...props} />
      </div>
      <Heading
        class="text-xl leading-snug font-medium tracking-tight text-foreground transition-colors duration-200 group-hover:text-accent sm:text-2xl"
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
      <p
        class="mt-1 line-clamp-2 max-w-[65ch] text-sm leading-relaxed text-foreground/70 sm:text-base"
      >
        {description}
      </p>
    </div>
    <span
      class="pointer-events-none absolute top-1/2 right-2 -translate-x-3 -translate-y-1/2 text-xl font-bold text-accent opacity-0 transition-all duration-300 ease-out group-hover:translate-x-0 group-hover:opacity-100"
      aria-hidden="true"
    >
      →
    </span>
  </a>
</li>
