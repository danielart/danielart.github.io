---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

interface Props {
  wide?: boolean;
}

const { wide = false } = Astro.props;
const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/80 backdrop-blur-md transition-all duration-300"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "flex flex-col justify-between py-4 sm:flex-row sm:items-center",
      wide ? "wide-layout" : "app-layout",
    ]}
  >
    <div class="flex w-full items-center justify-between sm:w-auto">
      <a
        href="/"
        class="py-1 text-xl font-bold tracking-tight whitespace-nowrap transition-colors hover:text-accent"
      >
        {SITE.title}
      </a>
      <button
        id="menu-btn"
        class="focus-outline rounded p-2 transition-colors hover:bg-muted/50 sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
    </div>

    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:w-auto sm:flex-row sm:justify-end sm:space-x-6 sm:py-0"
    >
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-full grid-cols-2 gap-2",
          "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-2 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1 sm:[&>li>a]:text-left",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:gap-x-6 sm:gap-y-0",
        ]}
      >
        <li>
          <a
            href="/posts"
            class:list={[
              { "active-nav": isActive("/posts") },
              "transition-colors",
            ]}
          >
            Posts
          </a>
        </li>
        <li>
          <a
            href="/tags"
            class:list={[
              { "active-nav": isActive("/tags") },
              "transition-colors",
            ]}
          >
            Tags
          </a>
        </li>
        <li>
          <a
            href="/about"
            class:list={[
              { "active-nav": isActive("/about") },
              "transition-colors",
            ]}
          >
            About
          </a>
        </li>
        <li>
          <a href="/#contact" class="transition-colors">Contact</a>
        </li>
        {
          SITE.showArchives && (
            <li>
              <LinkButton
                href="/archives"
                class:list={[
                  "focus-outline flex justify-center p-2 transition-colors sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                  },
                ]}
                title="Archives"
                aria-label="archives"
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only">Archives</span>
              </LinkButton>
            </li>
          )
        }
        <li class="flex items-center justify-center">
          <LinkButton
            href="/search"
            class:list={[
              "focus-outline flex p-2 transition-colors sm:p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Search"
            aria-label="search"
          >
            <IconSearch />
            <span class="sr-only">Search</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-10 p-2 transition-colors sm:size-8 hover:[&>svg]:stroke-accent"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
